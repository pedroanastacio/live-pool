{
  "name": "worker",
  "version": "0.0.1",
  "description": "Vote processing worker",
  "private": true,
  "main": "./dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "@live-pool/database": "workspace:*",
    "@live-pool/messaging": "workspace:*",
    "dotenv": "^17.3.1",
    "ioredis": "^5.4.2"
  },
  "devDependencies": {
    "@live-pool/eslint-config": "workspace:*",
    "@live-pool/typescript-config": "workspace:*",
    "@types/node": "^22.10.7",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
